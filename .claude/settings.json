{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "ruff check --fix src tests && ruff format src tests && mypy src" }
        ]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "pytest -q" }] }
    ]
  }
}
